{
    "name": "maya/shared-profile-laravel",
    "description": "Shared user profile endpoints (GET /me, PUT /me/locale) for Maya Laravel microservices. Provides Controller, FormRequest, Service, Repository contracts, DTO and Resource. Apps extend behaviour via UserProfileResolverInterface and LocaleWriterInterface.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/Maya-AQSS/shared-profile-laravel",
    "support": {
        "issues": "https://github.com/Maya-AQSS/shared-profile-laravel/issues",
        "source": "https://github.com/Maya-AQSS/shared-profile-laravel"
    },
    "version": "0.1.0",
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/validation": "^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "Maya\\Profile\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maya\\Profile\\Providers\\SharedProfileServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
