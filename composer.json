{
    "name": "ceedcv-maya/shared-profile-laravel",
    "description": "User profile endpoints for Laravel + Keycloak: GET /me, PUT /me/locale, configurable resolvers, FormRequest validation.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/Maya-AQSS/shared-profile-laravel",
    "support": {
        "issues": "https://github.com/Maya-AQSS/maya_platform/issues",
        "source": "https://github.com/Maya-AQSS/shared-profile-laravel"
    },
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/validation": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "orchestra/testbench": "^9.0 || ^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Maya\\Profile\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest --colors=always",
        "test-coverage": "pest --coverage --min=80"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maya\\Profile\\Providers\\SharedProfileServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "keywords": [
        "laravel",
        "keycloak",
        "profile",
        "me",
        "locale",
        "ceedcv",
        "maya"
    ],
    "authors": [
        {
            "name": "CEEDCV",
            "email": "info@ceedcv.es",
            "homepage": "https://ceedcv.es"
        }
    ]
}
